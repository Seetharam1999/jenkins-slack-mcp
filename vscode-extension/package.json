{
  "name": "buildpilot",
  "displayName": "BuildPilot",
  "description": "Trigger Jenkins builds directly from your IDE. Auto-discovers jobs, supports parameterized builds, and sends Slack notifications.",
  "version": "1.0.0",
  "publisher": "seetharam1999",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other", "Testing"],
  "keywords": ["jenkins", "ci", "cd", "build", "deploy", "continuous integration", "continuous deployment", "devops", "pipeline", "slack"],
  "icon": "media/buildpilot-icon.png",
  "repository": { "type": "git", "url": "https://github.com/Seetharam1999/buildpilot" },
  "activationEvents": ["onStartupFinished"],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "buildpilot",
          "title": "BuildPilot",
          "icon": "media/buildpilot.svg"
        }
      ]
    },
    "views": {
      "buildpilot": [
        { "id": "buildpilot.search", "name": "Search", "type": "webview" },
        { "id": "buildpilot.jobs", "name": "Jobs" },
        { "id": "buildpilot.history", "name": "Build History" }
      ]
    },
    "commands": [
      { "command": "buildpilot.login", "title": "BuildPilot: Login to Jenkins" },
      { "command": "buildpilot.triggerBuild", "title": "BuildPilot: Trigger Build" },
      { "command": "buildpilot.refreshJobs", "title": "BuildPilot: Refresh Jobs", "icon": "$(refresh)" },
      { "command": "buildpilot.connectSlack", "title": "BuildPilot: Connect Slack" },
      { "command": "buildpilot.multiTrigger", "title": "BuildPilot: Trigger Multiple Jobs" },
      { "command": "buildpilot.cancelBuild", "title": "BuildPilot: Cancel Build" },
      { "command": "buildpilot.showBuildSummary", "title": "BuildPilot: Show Build Summary" },
      { "command": "buildpilot.pinJob", "title": "Pin Job", "icon": "$(pin)" },
      { "command": "buildpilot.unpinJob", "title": "Unpin Job", "icon": "$(pinned)" },
      { "command": "buildpilot.pinGroup", "title": "Pin Group", "icon": "$(pin)" },
      { "command": "buildpilot.unpinGroup", "title": "Unpin Group", "icon": "$(pinned)" },
      { "command": "buildpilot.searchJobs", "title": "BuildPilot: Search Jobs", "icon": "$(search)" },
      { "command": "buildpilot.clearSearch", "title": "BuildPilot: Clear Search", "icon": "$(close)" },
      { "command": "buildpilot.openSettings", "title": "BuildPilot: Settings", "icon": "$(gear)" },
      { "command": "buildpilot.logout", "title": "BuildPilot: Logout" }
    ],
    "menus": {
      "view/title": [
        { "command": "buildpilot.refreshJobs", "when": "view == buildpilot.jobs", "group": "navigation" },
        { "command": "buildpilot.openSettings", "when": "view == buildpilot.jobs", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "buildpilot.pinJob", "when": "view == buildpilot.jobs && viewItem == job", "group": "inline" },
        { "command": "buildpilot.unpinJob", "when": "view == buildpilot.jobs && viewItem == pinnedJob", "group": "inline" },
        { "command": "buildpilot.pinGroup", "when": "view == buildpilot.jobs && viewItem == group", "group": "inline" },
        { "command": "buildpilot.unpinGroup", "when": "view == buildpilot.jobs && viewItem == pinnedGroup", "group": "inline" }
      ]
    },
    "configuration": {
      "title": "BuildPilot",
      "properties": {
        "buildpilot.jenkinsUrl": { "type": "string", "default": "", "description": "Jenkins base URL" },
        "buildpilot.slackNotify": { "type": "boolean", "default": true, "description": "Send Slack DM on build trigger" },
        "buildpilot.defaultBranch": { "type": "string", "default": "main", "description": "Default branch for builds" }
      }
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.2",
    "open": "^9.1.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0"
  }
}
